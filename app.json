{
  "expo": {
    "name": "kiddo-assignment",
    "slug": "kiddo-assignment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1eaef71d-c3e5-4a01-9b96-a0e2c0a5fb6d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saurabhgupta.kiddoassignment"
    },
    "android": {
      "package": "com.saurabhgupta.kiddoassignment"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1eaef71d-c3e5-4a01-9b96-a0e2c0a5fb6d"
      }
    }
  }
}